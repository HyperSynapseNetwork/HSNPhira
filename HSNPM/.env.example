# HSNPM 通知服务环境变量配置

# 服务器端口
PORT=3030

# VAPID 密钥（用于 Web-Push）
# 生成命令：openssl ecparam -genkey -name prime256v1 -out private_key.pem
# 然后提取公钥：openssl ec -in private_key.pem -pubout -out public_key.pem
# 将私钥内容（PEM格式）设置为 VAPID_PRIVATE_KEY
VAPID_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END EC PRIVATE KEY-----"
VAPID_PUBLIC_KEY="YOUR_PUBLIC_KEY_HERE"
VAPID_SUBJECT="mailto:admin@example.com"

# 远程 Phira 服务器地址（用于监听房间事件）
REMOTE_PHIRA_SERVER="https://phira.htadiy.com"
# 可选：代理模式（本地开发时可能需要）
# USE_PROXY=false
# PROXY_URL="http://localhost:3000"

# 日志级别
RUST_LOG="info"