# 开发环境配置
# 后端API服务器地址
VITE_API_TARGET=https://phira.htadiy.com

# 是否启用API代理（开发环境推荐为true）
VITE_USE_PROXY=true

# 排行榜API基础地址
VITE_RANK_API_BASE_URL=https://phira.htadiy.com/rankapi

# HSNPM 通知服务配置
VITE_HSNPM_SERVER=/hsnpm-api
# VAPID 公钥（需要与 HSNPM 服务器的 VAPID_PUBLIC_KEY 一致）
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
