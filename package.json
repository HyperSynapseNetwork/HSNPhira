{
  "name": "hsnphira-frontend",
  "version": "1.1.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-icons.js && vue-tsc && vite build && node scripts/generate-seo-files.js",
    "build:ssg": "node scripts/generate-icons.js && vue-tsc && vite-ssg build && node scripts/generate-seo-files.js",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-seo": "node scripts/generate-seo-files.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "marked": "^17.0.3",
    "pinia": "^2.1.7",
    "vite-ssg": "^0.23.8",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vue-tsc": "^2.0.0"
  }
}
