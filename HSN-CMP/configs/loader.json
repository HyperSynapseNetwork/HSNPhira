    {"key": "plugin_default_install_method", "type": "enum", "name_cn": "插件默认安装方式", "description_cn": "插件依赖的默认安装方式。", "options": [{"value":"pip","name_cn":"pip"},{"value":"none","name_cn":"不自动安装"}], "default": "pip"}
    ,{"key": "auto_start_plugins", "type": "boolean", "name_cn": "启动时自动启动插件", "description_cn": "如果为 true，loader 启动时会按 priority 自动启动插件。", "default": true}
